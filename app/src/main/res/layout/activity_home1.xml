<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".home.HomeActivity"
    android:background="@color/white"
    android:weightSum="5"
    android:orientation="vertical">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3.7"
        android:weightSum="5"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/lin_dr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.33"
            android:orientation="vertical"
            android:weightSum="3">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_doctors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:descendantFocusability="afterDescendants"/>

            <Button
                android:id="@+id/btn_settings"
                android:layout_width="180dp"
                android:layout_height="50dp"
                android:background="@drawable/buttonbgsave"
                android:text="Settings"

                android:layout_marginTop="10dp"
                android:visibility="visible"
                android:gravity="center"
                android:layout_gravity="center"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18dp" />



        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3.7"
            android:scaleType="fitXY">
<!--            <ImageView-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:src="@drawable/homebg"-->
<!--                android:scaleType="fitXY">-->
<!--            </ImageView>-->
            <VideoView
                android:id="@+id/videoView_ID"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                />

        </LinearLayout>

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.3"
        android:orientation="vertical"
        android:background="@color/red"
        android:gravity="center"
        android:weightSum="3">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:background="#191b40"
            android:gravity="center_vertical"
            >
        <TextView
            android:id="@+id/scrollingtitle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="5dp"
            android:layout_weight="1.9"
            android:textSize="60dp"
            android:text=""
            android:textFontWeight="900"
            android:singleLine="true"
            android:gravity="center_vertical"
            android:fontFamily="@font/manjari"
            android:textColor="@color/white"
            android:scrollHorizontally="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit ="marquee_forever"/>
        </LinearLayout>

       <TextView
           android:id="@+id/scrollingtext"
           android:layout_width="match_parent"
          android:layout_height="0dp"
           android:layout_weight="0.9"
            android:text=""
           android:textSize="29dp"
            android:textColor="@color/white"
            android:textStyle="bold"
           android:singleLine="true"
          android:scrollHorizontally="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit ="marquee_forever"/>

    </LinearLayout>

</LinearLayout>